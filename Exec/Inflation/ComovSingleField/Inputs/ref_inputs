# ------------------  INPUTS TO MAIN PROGRAM  -------------------

# If restarting from a checkpoint, specify the checkpoint.
# amr.restart               = ./chk00999


# New KG Axionyx inputs  --PH
# ####################### #
# AXIONYX PARAMETERS      #
# ####################### #

KG.simType                = 1           # Generalised Monodromy
KG.ICType                 = 3           # 0 = uniform, 1 = fixed_k, 2 = delta_k (i.e., fixed_k in momentum space), 3 = standard 
KG.KG_k                   = 4           # 
KG.cutoff_k               = 4           # 
# KG.mass                   = 2.0e-5       # As per Amin, Easther,  et al. 
KG.mass                   = 0.06       # Testing 
KG.MASS                   = 0.001        #
KG.power                  = 0.50        # 
KG.KG0                    = 0.006       # 
# N.B.: A = 1/f0, B = 0.009486832981

# ####################### #
# NYX PARAMETERS          #
# ####################### #

# ## End condition
max_step                 = 400        # Maximum number of level 0 steps 
# stop_time                = 20.1     # Final simulation time

# ## Integration methods
ax.interpolator          = 1           # 1 = bilinear interpolation , 2 = quartic interpolation

# ## Diagnostics & verbosity
ax.v                     = 0           # Verbosity ranges from 0 (least) to 3 (most)

# ## Nyx physics 
ax.dt_cutoff  = 5.e-23                 # Time step below which calculation will abort   ## NECESSARY
ax.lo_bc = 0 0 0                       # Boundary types: 0 = interior/periodic, 1 = inflow, 2 = outflow, 3 = symmetry
ax.hi_bc = 0 0 0                       #                 4 = slip wall, 5 = no-slip wall. We'll only use 0.
ax.fixed_dt = 0.05                     # As per LatticeEasy ONEFLDLAMBDA example
                                       # Use a fixed time-step. I might make this the only one in Axionyx_KG 
                                       # For more, see https://amrex-astro.github.io/Nyx/docs_html/NyxInputs.html#regridding
 
# ####################### #
# AMREX PARAMETERS        #
# ####################### #

# ## Problem size & geometry
geometry.is_periodic      = 1 1 1            # Periodic = 1; Fixed = 0
geometry.coord_sys        = 0                # Cartesian = 0
geometry.prob_lo          = 0.0 0.0 0.0      # Physical location of lower corner of domain (in Program units)
geometry.prob_hi          = 30.0 30.0 30.0   # Physical location of upper corner of domain (in Program units) 
amr.n_cell                = 128 128 128      # Number of cells in x y z
amr.max_grid_size         = 64 128 256       # Max number of cells in a grid (used for parallelizing)
amr.blocking_factor       = 4               # Dimension of grids is a multiple of this. Can have one for each level

# ## Diagnostics & verbosity
amr.v                     = 0                # Verbosity ranges from 0 (least) to 3 (most)
amr.grid_log              = grdlog           # Name of grid logging file

# ## Refinement / regridding 
amr.max_level             = 2                # Maximum refinement level number allowed
amr.ref_ratio             = 2 2 2 2 2        # Refinement ratio between levels (0->1) (1->2) (2->3) etc.
amr.regrid_int            = 2 2 4 8          # When to re-grid per level (0 1 2 etc.)
amr.n_error_buf           = 2                # "Buffer" cells to include around refined grid
#amr.refine_grid_layout   = 1                # True (1) or False (0), add more grids until number of 
                                             # grids == number of processors
amr.regrid_on_restart     = 1                # Whether or not to regrid (update refinement) on restart 
amr.subcycling_mode       = Manual           # Auto, None, or Manual --- subcycling is taking more time
                                             # steps in refined layers [NOT USED YET]
amr.subcycling_iterations = 1                # How many more time steps to take. Can specify each layer    
                                             # or give one number for all (N.B. level 0 must always be 1, 
                                             # as it is the reference layer) [NOT USED YET]
amr.grid_eff              = 0.9              # At grid creation (refinement), fraction of grid cells that 
                                             # must contain tagged cells
amr.n_proper              = 0                # "Cells required for proper nesting"

## Specific to Sim
amr.refinement_indicators = EdensRel EdensRel2       # The interesting areas to focus computational power (E.g., clusters)

# First refinement
amr.EdensRel.value_greater  = 2.5 
amr.EdensRel.field_name     = EdensRel
amr.EdensRel.max_level      = 1
amr.EdensRel.start_time     = 10. # n = 200
# amr.EdensRel.start_time     = 7.5  # n = 150
# amr.EdensRel.start_time     = 12.5 # n = 250
# amr.EdensRel.start_time     = 17.5 # n = 350

# Second refinement
amr.EdensRel2.value_greater  = 10.0 
amr.EdensRel2.field_name     = EdensRel
amr.EdensRel2.max_level      = 2
amr.EdensRel2.start_time     = 12.5 

# ## Checkpoint files
amr.check_file            = chk              # The prefix of checkpoint folder names
amr.check_int             = 50               # The interval of steps at which to save checkpoints

# ## Plotfiles
amr.plot_file             = plt              # The prefix of plot folder names
amr.plot_int              = 50               # The interval of steps at which to save plots 

# ## Log file 
amr.data_log = runlog rholog                 # The name of the run log. If desired, rholog can also be included

# ## Output field names
amr.plot_vars = KGfpr KGfVpr                   # Primitive fields output in plot folders/checkpoints
                                               # KGfpr and KGfVpr are the field and time-derivative in program units
amr.derive_plot_vars = KGf KGfv KGfdens Edens  # Derived fields output in plot folders/checkpoints 
                                               # Options are: KGf, KGfv (field and time-dv in Natural units), 
                                               # KGfdens (field^2 in Natural units), Edens (energy in Natural units)
                                               # Egrad, Epot, and Ekin (the gradient, potential, and kinetic energies)
# ## Other
amr.probin_file = ""                         # TODO (Don't know what this is yet, but it crashes without it).

