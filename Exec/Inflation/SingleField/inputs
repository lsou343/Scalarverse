KG.simType                = 0           # Single Field Quartic 
KG.ICType                 = 3           # 0 = uniform, 1 = fixed_k, 2 = delta_k (i.e., fixed_k in momentum space), 3 = standard 
KG.KG_k                   = 3           # 
KG.cutoff_k               = 4           # 
KG.mass                   = 1.e-7       # As per the LatticeEasy ONEFLDLAMBDA model.
# ax.mass                   = 0.        # As per the LatticeEasy ONEFLDLAMBDA model.
# KG.lambda                 = 0.          # As per the LatticeEasy ONEFLDLAMBDA model.
KG.lambda                 = 9.e-14    # As per the LatticeEasy ONEFLDLAMBDA model.
# KG.KG0                    = 0.342052       # As per the LatticeEasy ONEFLDLAMBDA model.
KG.KG0                    = 0.342       # As per the LatticeEasy ONEFLDLAMBDA model.
KG.beta                   = 4           # As per the LatticeEasy ONEFLDLAMBDA model.

# ####################### #
# NYX PARAMETERS          #
# ####################### #

# ## End condition
# max_step                 = 1000          # Maximum number of level 0 steps 
max_step                 = 1          # Maximum number of level 0 steps 
# stop_time                 = 200.0      # Final simulation time
# ax.final_a                           # Final value of a
# ax.final_z                           # Final value of z

# ## Integration methods
# ax.levelmethod           = 0 0 0 0   # which method to use 3=spectral, 0=finite_difference
# ax.order                 = 2         # nth order spectral method 2 or 6
ax.interpolator          = 1           # 1 = bilinear interpolation , 2 = quartic interpolation

# ## Diagnostics & verbosity
ax.v                     = 0           # Verbosity ranges from 0 (least) to 3 (most)
particles.v = 0                         # TODO

# ## Nyx physics 
# ax.comoving_OmB = 0.0                  # Omega_baryon --- baryon fractional energy density.
# ax.comoving_OmM = 1.0                  # Omega_matter --- total matter fractional energy density. (i.e., pure matter)
# ax.comoving_OmR = 0.0                  # Omega_radiation --- total radiation fractional energy density. 
