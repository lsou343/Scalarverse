# ## Checkpoint files
amr.check_file            = chk              # The prefix of checkpoint folder names
amr.check_int             = 100              # The interval of steps at which to save checkpoints

# ## Plotfiles
amr.plot_file             = plt              # The prefix of plot folder names
amr.plot_int              = 50               # The interval of steps at which to save plots 

# ## Log file 
amr.data_log = runlog                        # The name of the run log

# ## Output field names
amr.plot_vars = KGfpr KGfVpr                 # Primitive fields output in plot folders/checkpoints
amr.derive_plot_vars = KGf KGfv KGfdens             # Derived fields output in plot folders/checkpoints 

